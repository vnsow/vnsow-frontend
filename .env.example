# =====================================================
# SMART INVESTMENT FRONTEND - VARIABLES DE ENTORNO (EJEMPLO)
# =====================================================
#
# INSTRUCCIONES PARA CONFIGURAR:
# 1. Copia este archivo y renómbralo a ".env"
# 2. Reemplaza "http://localhost:8000" con la URL de tu backend
# 3. Para DESARROLLO LOCAL: usa http://localhost:8000
# 4. Para PRODUCCIÓN: usa la URL de tu backend desplegado (ej: Render, Heroku, etc.)
#
# =====================================================

# ============ DESARROLLO LOCAL ============
# URL del backend en localhost
REACT_APP_BACKEND_URL=http://localhost:8000

# ============ PRODUCCIÓN ============
# Descomenta y usa esta variable cuando hagas build para producción:
# REACT_APP_BACKEND_URL=https://tu-backend.onrender.com

